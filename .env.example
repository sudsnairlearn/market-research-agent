# Required: Nebius AI Studio API key (OpenAI-compatible). Get one at https://studio.nebius.com
NEBIUS_API_KEY=...

# Required for live web research. Free key at https://tavily.com
TAVILY_API_KEY=tvly-...

# Optional overrides
# Any model served by Nebius, e.g.:
#   meta-llama/Llama-3.3-70B-Instruct
#   Qwen/Qwen2.5-72B-Instruct
#   deepseek-ai/DeepSeek-V3
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct
# Default endpoint; if your account uses Nebius Token Factory, set:
#   https://api.tokenfactory.nebius.com/v1/
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/
MAX_COMPETITORS=3
SEARCHES_PER_COMPETITOR=4
